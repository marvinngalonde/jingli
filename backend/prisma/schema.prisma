  teacher        Staff    @relation(fields: [assessedBy], references: [id])
  school         School   @relation(fields: [schoolId], references: [id])
  student        Student  @relation(fields: [studentId], references: [id])
  subject        Subject  @relation(fields: [subjectId], references: [id])
  term           ExamTerm @relation(fields: [termId], references: [id])

  @@map("cala_records")
}

model GradeScale {
  id       String       @id @default(uuid())
  schoolId String       @map("school_id")
  name     String
  system   GradeSystem  @default(CUSTOM)
  ranges   GradeRange[]
  school   School       @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, name])
  @@map("grade_scales")
}

model GradeRange {
  id          String     @id @default(uuid())
  scaleId     String     @map("scale_id")
  grade       String
  symbol      String?
  minPercent  Float      @map("min_percent")
  maxPercent  Float      @map("max_percent")
  points      Float?
  description String?
  scale       GradeScale @relation(fields: [scaleId], references: [id], onDelete: Cascade)

  @@map("grade_ranges")
}

model MedicalProfile {
  id                 String   @id @default(uuid())
