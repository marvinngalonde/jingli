generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                String             @id @default(uuid())
  name              String
  subdomain         String             @unique
  logoUrl           String?            @map("logo_url")
  config            Json?
  createdAt         DateTime           @default(now()) @map("created_at")
  academicYears     AcademicYear[]
  alertLogs         AlertLog[]
  alertTemplates    AlertTemplate[]
  assetCategories   AssetCategory[]
  assets            Asset[]
  attendance        Attendance[]
  staffAttendance   StaffAttendance[]
  bedAllocations    BedAllocation[]
  bookCirculations  BookCirculation[]
  calaRecords       CalaRecord[]
  classes           ClassLevel[]
  clinicVisits      ClinicVisit[]
  disciplineRecords DisciplineRecord[]
  DiscussionThread  DiscussionThread[]
  events            Event[]
  examTerms         ExamTerm[]
  exams             Exam[]
  exchangeRates     ExchangeRate[]
  exeats            Exeat[]
  expenses          Expense[]
  feeHeads          FeeHead[]
  feeStructures     FeeStructure[]
  gatePasses        GatePass[]
  gradeScales       GradeScale[]
  hostels           Hostel[]
  inquiries         Inquiry[]
  invoices          Invoice[]
  lateArrivals      LateArrival[]
  books             Book[]
  liveClasses       LiveClass[]
  notices           Notice[]
  quizzes           Quiz[]
  reportLogs        ReportLog[]
  rooms             Room[]
  routes            Route[]
  salaryPayments    SalaryPayment[]
  sections          ClassSection[]
  staff             Staff[]
  studentRoutes     StudentRoute[]
  students          Student[]
  subjects          Subject[]
  transactions      Transaction[]
  users             User[]
  vehicles          Vehicle[]
  visitors          Visitor[]

  status            SchoolStatus       @default(ACTIVE)
  aiEnabled         Boolean            @default(false) @map("ai_enabled")
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at")

  @@map("schools")
}

model User {
  id                 String          @id @default(uuid())
  schoolId           String?         @map("school_id")
  supabaseUid        String?         @unique @map("supabase_uid")
  username           String          @map("username")
  email              String?
  passwordHash       String          @map("password_hash")
  role               UserRole
  status             UserStatus      @default(ACTIVE)
  avatarUrl          String?         @map("avatar_url")
  createdAt          DateTime        @default(now()) @map("created_at")
  lastLogin          DateTime?       @map("last_login")
  aiChatSessions     AiChatSession[]
  recordedAttendance     Attendance[]    @relation("AttendanceRecorder")
  recordedStaffAttendance StaffAttendance[] @relation("StaffAttendanceRecorder")
  approvedExpenses   Expense[]       @relation("ExpenseApprover")
  issuedPasses       GatePass[]      @relation("PassIssuer")
  guardianProfile    Guardian?
  recordedLate       LateArrival[]   @relation("LateRecorder")
  receivedMessages   Message[]       @relation("Receiver")
  sentMessages       Message[]       @relation("Sender")
  postedNotices      Notice[]
  notifications      Notification[]
  processedSalaries  SalaryPayment[] @relation("SalaryProcessor")
  staffProfile       Staff?
  studentProfile     Student?
  collectedPayments  Transaction[]   @relation("PaymentCollector")
  school             School?         @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, username])
  @@unique([schoolId, email])
  @@map("users")
}

model Permission {
  id              String           @id @default(uuid())
  module          String
  action          String
  description     String?
  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  role         UserRole
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([role, permissionId])
  @@map("role_permissions")
}

model Guardian {
  id           String            @id @default(uuid())
  schoolId     String            @map("school_id")
  userId       String            @unique @map("user_id")
  firstName    String            @map("first_name")
  lastName     String            @map("last_name")
  phone        String?
  address      String?
  relationship String
  occupation   String?
  user         User              @relation(fields: [userId], references: [id])
  students     StudentGuardian[]

  @@map("guardians")
}

model AcademicYear {
  id            String         @id @default(uuid())
  schoolId      String         @map("school_id")
  name          String
  startDate     DateTime       @map("start_date")
  endDate       DateTime       @map("end_date")
  current       Boolean        @default(false)
  school        School         @relation(fields: [schoolId], references: [id])
  examTerms     ExamTerm[]
  feeStructures FeeStructure[]

  @@map("academic_years")
}

model ClassLevel {
  id            String         @id @default(uuid())
  schoolId      String         @map("school_id")
  name          String
  level         Int
  school        School         @relation(fields: [schoolId], references: [id])
  exams         Exam[]
  feeStructures FeeStructure[]
  sections      ClassSection[]
  subjects      Subject[]      @relation("ClassLevelToSubject")

  @@map("classes")
}

model ClassSection {
  id                 String              @id @default(uuid())
  schoolId           String              @map("school_id")
  classLevelId       String              @map("class_id")
  name               String
  capacity           Int                 @default(30)
  classTeacherId     String?             @map("class_teacher_id")
  assignments        Assignment[]
  attendance         Attendance[]
  courseMaterials    CourseMaterial[]
  LiveClass          LiveClass[]
  Quiz               Quiz[]
  classLevel         ClassLevel          @relation(fields: [classLevelId], references: [id])
  classTeacher       Staff?              @relation(fields: [classTeacherId], references: [id])
  school             School              @relation(fields: [schoolId], references: [id])
  students           Student[]
  subjectAllocations SubjectAllocation[]
  timetables         Timetable[]

  @@map("sections")
}

model Subject {
  id              String              @id @default(uuid())
  schoolId        String              @map("school_id")
  name            String
  code            String
  department      String?
  teacherId       String?             @map("teacher_id")
  assignments     Assignment[]
  calaRecords     CalaRecord[]
  courseMaterials CourseMaterial[]
  exams           Exam[]
  liveClasses     LiveClass[]
  quizzes         Quiz[]
  allocations     SubjectAllocation[]
  school          School              @relation(fields: [schoolId], references: [id])
  teacher         Staff?              @relation(fields: [teacherId], references: [id])
  timetables      Timetable[]
  classLevels     ClassLevel[]        @relation("ClassLevelToSubject")

  @@unique([schoolId, code])
  @@map("subjects")
}

model SubjectAllocation {
  id        String       @id @default(uuid())
  staffId   String       @map("staff_id")
  subjectId String       @map("subject_id")
  sectionId String       @map("section_id")
  section   ClassSection @relation(fields: [sectionId], references: [id])
  staff     Staff        @relation(fields: [staffId], references: [id])
  subject   Subject      @relation(fields: [subjectId], references: [id])

  @@map("subject_allocations")
}

model Student {
  id                String             @id @default(uuid())
  schoolId          String             @map("school_id")
  userId            String             @unique @map("user_id")
  admissionNo       String             @map("admission_no")
  rollNo            String?            @map("roll_no")
  sectionId         String             @map("section_id")
  enrollmentDate    DateTime           @map("enrollment_date")
  firstName         String             @map("first_name")
  lastName          String             @map("last_name")
  dob               DateTime?
  gender            String?
  address           String?
  attendance        Attendance[]
  bedAllocations    BedAllocation[]
  bookCirculations  BookCirculation[]
  calaRecords       CalaRecord[]
  clinicVisits      ClinicVisit[]
  disciplineRecords DisciplineRecord[]
  examResults       ExamResult[]
  exeats            Exeat[]
  gatePasses        GatePass[]
  invoices          Invoice[]
  lateArrivals      LateArrival[]
  medicalProfile    MedicalProfile?
  quizAttempts      QuizAttempt[]
  guardians         StudentGuardian[]
  transportRoutes   StudentRoute[]
  school            School             @relation(fields: [schoolId], references: [id])
  section           ClassSection       @relation(fields: [sectionId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  submissions       Submission[]

  @@unique([schoolId, admissionNo])
  @@map("students")
}

model StudentGuardian {
  studentId  String   @map("student_id")
  guardianId String   @map("guardian_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  guardian   Guardian @relation(fields: [guardianId], references: [id])
  student    Student  @relation(fields: [studentId], references: [id])

  @@id([studentId, guardianId])
  @@map("student_guardians")
}

model Staff {
  id                 String              @id @default(uuid())
  schoolId           String              @map("school_id")
  userId             String              @unique @map("user_id")
  employeeId         String              @map("employee_id")
  designation        String
  department         String
  joinDate           DateTime            @map("join_date")
  firstName          String              @map("first_name")
  lastName           String              @map("last_name")
  phone              String?
  baseSalary         Decimal             @default(0) @map("base_salary")
  assignments        Assignment[]
  calaRecords        CalaRecord[]
  courseMaterials    CourseMaterial[]
  disciplineRecords  DisciplineRecord[]
  attendance         StaffAttendance[]
  gradedExams        ExamResult[]
  liveClasses        LiveClass[]
  quizzes            Quiz[]
  salaryPayments     SalaryPayment[]
  classTeacherOf     ClassSection[]
  school             School              @relation(fields: [schoolId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  subjectAllocations SubjectAllocation[]
  subjects           Subject[]
  timetables         Timetable[]

  @@unique([schoolId, employeeId])
  @@map("staff")
}

model Timetable {
  id        String       @id @default(uuid())
  sectionId String       @map("section_id")
  subjectId String       @map("subject_id")
  teacherId String       @map("teacher_id")
  day       DayOfWeek
  startTime DateTime     @map("start_time")
  endTime   DateTime     @map("end_time")
  roomNo    String?      @map("room_no")
  section   ClassSection @relation(fields: [sectionId], references: [id])
  subject   Subject      @relation(fields: [subjectId], references: [id])
  teacher   Staff        @relation(fields: [teacherId], references: [id])

  @@map("timetables")
}

model Assignment {
  id          String       @id @default(uuid())
  sectionId   String       @map("section_id")
  subjectId   String       @map("subject_id")
  teacherId   String       @map("teacher_id")
  title       String
  description String?
  dueDate     DateTime     @map("due_date")
  maxMarks    Int          @map("max_marks")
  type        String
  section     ClassSection @relation(fields: [sectionId], references: [id])
  subject     Subject      @relation(fields: [subjectId], references: [id])
  teacher     Staff        @relation(fields: [teacherId], references: [id])
  submissions Submission[]

  @@map("assignments")
}

model Submission {
  id           String     @id @default(uuid())
  assignmentId String     @map("assignment_id")
  studentId    String     @map("student_id")
  submittedAt  DateTime   @default(now()) @map("submitted_at")
  fileUrl      String?    @map("file_url")
  content      String?    @db.Text
  marks        Int?
  feedback     String?
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  student      Student    @relation(fields: [studentId], references: [id])

  @@map("submissions")
}

model CourseMaterial {
  id          String       @id @default(uuid())
  title       String
  description String?
  fileUrl     String       @map("file_url")
  fileType    String?      @map("file_type")
  uploadedAt  DateTime     @default(now()) @map("uploaded_at")
  teacherId   String       @map("teacher_id")
  subjectId   String       @map("subject_id")
  sectionId   String       @map("section_id")
  section     ClassSection @relation(fields: [sectionId], references: [id])
  subject     Subject      @relation(fields: [subjectId], references: [id])
  teacher     Staff        @relation(fields: [teacherId], references: [id])

  @@map("course_materials")
}

model Attendance {
  id         String           @id @default(uuid())
  schoolId   String           @map("school_id")
  studentId  String           @map("student_id")
  sectionId  String           @map("section_id")
  date       DateTime         @db.Date
  status     AttendanceStatus
  remarks    String?
  recordedBy String           @map("recorded_by")
  recorder   User             @relation("AttendanceRecorder", fields: [recordedBy], references: [id])
  school     School           @relation(fields: [schoolId], references: [id])
  section    ClassSection     @relation(fields: [sectionId], references: [id])
  student    Student          @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
  @@index([sectionId, date])
  @@map("attendance")
}

model StaffAttendance {
  id           String    @id @default(uuid())
  schoolId     String    @map("school_id")
  staffId      String    @map("staff_id")
  date         DateTime  @db.Date
  checkInTime  DateTime? @map("check_in_time")
  checkOutTime DateTime? @map("check_out_time")
  status       String    @default("PRESENT")
  notes        String?
  recordedBy   String?   @map("recorded_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  recorder     User?     @relation("StaffAttendanceRecorder", fields: [recordedBy], references: [id])
  school       School    @relation(fields: [schoolId], references: [id])
  staff        Staff     @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@map("staff_attendance")
}

model FeeHead {
  id         String             @id @default(uuid())
  schoolId   String             @map("school_id")
  name       String
  type       String
  school     School             @relation(fields: [schoolId], references: [id])
  items      FeeStructureItem[]
  structures FeeStructure[]

  @@map("fee_heads")
}

model FeeStructure {
  id             String             @id @default(uuid())
  schoolId       String             @map("school_id")
  academicYearId String             @map("academic_year_id")
  classLevelId   String             @map("class_id")
  feeHeadId      String?            @map("fee_head_id")
  name           String
  amount         Decimal
  frequency      FeeFrequency
  currency       String             @default("USD")
  items          FeeStructureItem[]
  academicYear   AcademicYear       @relation(fields: [academicYearId], references: [id])
  classLevel     ClassLevel         @relation(fields: [classLevelId], references: [id])
  feeHead        FeeHead?           @relation(fields: [feeHeadId], references: [id])
  school         School             @relation(fields: [schoolId], references: [id])
  invoices       Invoice[]

  @@map("fee_structures")
}

model FeeStructureItem {
  id             String       @id @default(uuid())
  feeStructureId String       @map("fee_structure_id")
  feeHeadId      String       @map("fee_head_id")
  amount         Decimal
  head           FeeHead      @relation(fields: [feeHeadId], references: [id])
  structure      FeeStructure @relation(fields: [feeStructureId], references: [id])

  @@map("fee_structure_items")
}

model Invoice {
  id             String        @id @default(uuid())
  schoolId       String        @map("school_id")
  studentId      String        @map("student_id")
  feeStructureId String?       @map("fee_structure_id")
  amount         Decimal
  dueDate        DateTime      @map("due_date")
  status         InvoiceStatus @default(PENDING)
  issueDate      DateTime      @default(now()) @map("issue_date")
  currency       String        @default("USD")
  feeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])
  school         School        @relation(fields: [schoolId], references: [id])
  student        Student       @relation(fields: [studentId], references: [id])
  transactions   Transaction[]

  @@map("invoices")
}

model Transaction {
  id          String        @id @default(uuid())
  schoolId    String        @map("school_id")
  invoiceId   String        @map("invoice_id")
  amount      Decimal
  method      PaymentMethod
  date        DateTime      @default(now())
  referenceNo String?       @map("reference_no")
  collectedBy String        @map("collected_by")
  currency    String        @default("USD")
  collector   User          @relation("PaymentCollector", fields: [collectedBy], references: [id])
  invoice     Invoice       @relation(fields: [invoiceId], references: [id])
  school      School        @relation(fields: [schoolId], references: [id])

  @@map("transactions")
}

model Visitor {
  id           String        @id @default(uuid())
  schoolId     String        @map("school_id")
  name         String
  phone        String
  purpose      String
  personToMeet String?       @map("person_to_meet")
  checkIn      DateTime      @default(now()) @map("check_in_time")
  checkOut     DateTime?     @map("check_out_time")
  idProof      String?       @map("id_proof")
  vehicleNo    String?       @map("vehicle_no")
  status       VisitorStatus @default(IN)
  school       School        @relation(fields: [schoolId], references: [id])

  @@map("visitors")
}

model Book {
  id           String            @id @default(uuid())
  schoolId     String            @map("school_id")
  title        String
  author       String
  isbn         String?
  category     String?
  accessionNo  String?           @map("accession_no")
  status       BookStatus        @default(AVAILABLE)
  createdAt    DateTime          @default(now()) @map("created_at")
  circulations BookCirculation[]
  school       School            @relation(fields: [schoolId], references: [id])

  @@map("library_books")
}

model BookCirculation {
  id         String            @id @default(uuid())
  schoolId   String            @map("school_id")
  bookId     String            @map("book_id")
  studentId  String            @map("student_id")
  issueDate  DateTime          @default(now()) @map("issue_date")
  dueDate    DateTime          @map("due_date")
  returnDate DateTime?         @map("return_date")
  status     CirculationStatus @default(ISSUED)
  remarks    String?
  book       Book              @relation(fields: [bookId], references: [id])
  school     School            @relation(fields: [schoolId], references: [id])
  student    Student           @relation(fields: [studentId], references: [id])

  @@map("book_circulations")
}

model GatePass {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  studentId    String   @map("student_id")
  reason       String
  issuedAt     DateTime @default(now()) @map("issued_at")
  issuedBy     String   @map("issued_by")
  guardianName String   @map("guardian_name")
  issuer       User     @relation("PassIssuer", fields: [issuedBy], references: [id])
  school       School   @relation(fields: [schoolId], references: [id])
  student      Student  @relation(fields: [studentId], references: [id])

  @@map("gate_passes")
}

model LateArrival {
  id          String   @id @default(uuid())
  schoolId    String   @map("school_id")
  studentId   String   @map("student_id")
  arrivalTime DateTime @default(now()) @map("arrival_time")
  reason      String
  reportedBy  String   @map("reported_by")
  recordedBy  String   @map("recorded_by")
  recorder    User     @relation("LateRecorder", fields: [recordedBy], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])

  @@map("late_arrivals")
}

model Inquiry {
  id            String  @id @default(uuid())
  schoolId      String  @map("school_id")
  applicantName String  @map("applicant_name")
  parentName    String  @map("parent_name")
  email         String
  phone         String
  targetClass   String  @map("target_class")
  status        String
  notes         String?
  assignedTo    String? @map("assigned_to")
  school        School  @relation(fields: [schoolId], references: [id])

  @@map("inquiries")
}

model Notice {
  id             String    @id @default(uuid())
  schoolId       String    @map("school_id")
  title          String
  content        String
  postedBy       String    @map("posted_by")
  targetAudience String    @map("target_audience")
  postedAt       DateTime  @default(now()) @map("posted_at")
  expiresAt      DateTime? @map("expires_at")
  poster         User      @relation(fields: [postedBy], references: [id])
  school         School    @relation(fields: [schoolId], references: [id])

  @@map("notices")
}

model Message {
  id         String    @id @default(uuid())
  senderId   String    @map("sender_id")
  receiverId String    @map("receiver_id")
  content    String
  sentAt     DateTime  @default(now()) @map("sent_at")
  readAt     DateTime? @map("read_at")
  receiver   User      @relation("Receiver", fields: [receiverId], references: [id])
  sender     User      @relation("Sender", fields: [senderId], references: [id])

  @@map("messages")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  title      String
  message    String
  type       String   @default("INFO")
  readStatus Boolean  @default(false) @map("read_status")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model ExamTerm {
  id             String       @id @default(uuid())
  schoolId       String       @map("school_id")
  name           String
  startDate      DateTime     @map("start_date")
  endDate        DateTime     @map("end_date")
  academicYearId String       @map("academic_year_id")
  calaRecords    CalaRecord[]
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  school         School       @relation(fields: [schoolId], references: [id])
  exams          Exam[]

  @@map("exam_terms")
}

model Exam {
  id           String       @id @default(uuid())
  schoolId     String       @map("school_id")
  subjectId    String       @map("subject_id")
  classLevelId String       @map("class_id")
  termId       String       @map("term_id")
  name         String
  date         DateTime
  startTime    DateTime     @map("start_time")
  duration     Int
  maxMarks     Float        @map("max_marks")
  results      ExamResult[]
  classLevel   ClassLevel   @relation(fields: [classLevelId], references: [id])
  school       School       @relation(fields: [schoolId], references: [id])
  subject      Subject      @relation(fields: [subjectId], references: [id])
  term         ExamTerm     @relation(fields: [termId], references: [id])

  @@map("exams")
}

model ExamResult {
  id            String  @id @default(uuid())
  examId        String  @map("exam_id")
  studentId     String  @map("student_id")
  marksObtained Float   @map("marks_obtained")
  remarks       String?
  gradedBy      String  @map("graded_by")
  exam          Exam    @relation(fields: [examId], references: [id])
  grader        Staff   @relation(fields: [gradedBy], references: [id])
  student       Student @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
  @@map("exam_results")
}

model AiChatSession {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  title     String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  messages  AiChatMessage[]
  user      User            @relation(fields: [userId], references: [id])

  @@map("ai_chat_sessions")
}

model AiChatMessage {
  id        String        @id @default(uuid())
  sessionId String        @map("session_id")
  role      String
  content   String
  createdAt DateTime      @default(now()) @map("created_at")
  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("ai_chat_messages")
}

model ReportLog {
  id          String   @id @default(uuid())
  schoolId    String   @map("school_id")
  name        String
  type        String
  status      String   @default("Ready")
  generatedBy String   @map("generated_by")
  fileUrl     String?  @map("file_url")
  parameters  Json?
  createdAt   DateTime @default(now()) @map("created_at")
  school      School   @relation(fields: [schoolId], references: [id])

  @@map("report_logs")
}

model Event {
  id          String   @id @default(uuid())
  schoolId    String   @map("school_id")
  title       String
  description String?
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  location    String?
  type        String   @default("GENERAL")
  allDay      Boolean  @default(false) @map("all_day")
  createdAt   DateTime @default(now()) @map("created_at")
  school      School   @relation(fields: [schoolId], references: [id])

  @@map("events")
}

model Expense {
  id          String        @id @default(uuid())
  schoolId    String        @map("school_id")
  description String
  category    String
  amount      Decimal
  currency    String        @default("USD")
  date        DateTime      @db.Date
  status      ExpenseStatus @default(PENDING)
  approvedBy  String?       @map("approved_by")
  receiptUrl  String?       @map("receipt_url")
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  approver    User?         @relation("ExpenseApprover", fields: [approvedBy], references: [id])
  school      School        @relation(fields: [schoolId], references: [id])

  @@map("expenses")
}

model SalaryPayment {
  id          String         @id @default(uuid())
  schoolId    String         @map("school_id")
  staffId     String         @map("staff_id")
  amount      Decimal
  currency    String         @default("USD")
  month       Int
  year        Int
  status      SalaryStatus   @default(PENDING)
  method      PaymentMethod?
  referenceNo String?        @map("reference_no")
  processedBy String?        @map("processed_by")
  processedAt DateTime?      @map("processed_at")
  notes       String?
  createdAt   DateTime       @default(now()) @map("created_at")
  allowances  Decimal        @default(0)
  baseSalary  Decimal        @default(0) @map("base_salary")
  deductions  Decimal        @default(0)
  processor   User?          @relation("SalaryProcessor", fields: [processedBy], references: [id])
  school      School         @relation(fields: [schoolId], references: [id])
  staff       Staff          @relation(fields: [staffId], references: [id])

  @@unique([staffId, month, year])
  @@map("salary_payments")
}

model ExchangeRate {
  id            String   @id @default(uuid())
  schoolId      String   @map("school_id")
  fromCurrency  String   @map("from_currency")
  toCurrency    String   @map("to_currency")
  rate          Decimal
  effectiveDate DateTime @map("effective_date") @db.Date
  source        String?
  createdAt     DateTime @default(now()) @map("created_at")
  school        School   @relation(fields: [schoolId], references: [id])

  @@map("exchange_rates")
}

model Vehicle {
  id              String    @id @default(uuid())
  schoolId        String    @map("school_id")
  regNumber       String    @map("reg_number")
  make            String?
  model           String?
  year            Int?
  capacity        Int       @default(50)
  status          String    @default("ACTIVE")
  insuranceExpiry DateTime? @map("insurance_expiry")
  nextServiceDate DateTime? @map("next_service_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  routes          Route[]
  school          School    @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, regNumber])
  @@map("vehicles")
}

model Route {
  id          String         @id @default(uuid())
  schoolId    String         @map("school_id")
  name        String
  description String?
  vehicleId   String?        @map("vehicle_id")
  driverName  String?        @map("driver_name")
  startTime   String?        @map("start_time")
  endTime     String?        @map("end_time")
  stops       Json?
  status      RouteStatus    @default(ACTIVE)
  createdAt   DateTime       @default(now()) @map("created_at")
  school      School         @relation(fields: [schoolId], references: [id])
  vehicle     Vehicle?       @relation(fields: [vehicleId], references: [id])
  students    StudentRoute[]

  @@map("routes")
}

model StudentRoute {
  id          String         @id @default(uuid())
  schoolId    String         @map("school_id")
  studentId   String         @map("student_id")
  routeId     String         @map("route_id")
  pickupPoint String?        @map("pickup_point")
  direction   RouteDirection @default(BOTH)
  createdAt   DateTime       @default(now()) @map("created_at")
  route       Route          @relation(fields: [routeId], references: [id])
  school      School         @relation(fields: [schoolId], references: [id])
  student     Student        @relation(fields: [studentId], references: [id])

  @@unique([studentId, routeId])
  @@map("student_routes")
}

model AssetCategory {
  id          String  @id @default(uuid())
  schoolId    String  @map("school_id")
  name        String
  description String?
  school      School  @relation(fields: [schoolId], references: [id])
  assets      Asset[]

  @@unique([schoolId, name])
  @@map("asset_categories")
}

model Asset {
  id            String         @id @default(uuid())
  schoolId      String         @map("school_id")
  categoryId    String         @map("category_id")
  name          String
  serialNo      String?        @map("serial_no")
  location      String?
  purchaseDate  DateTime?      @map("purchase_date")
  purchasePrice Decimal?       @map("purchase_price")
  condition     AssetCondition @default(NEW)
  quantity      Int            @default(1)
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  category      AssetCategory  @relation(fields: [categoryId], references: [id])
  school        School         @relation(fields: [schoolId], references: [id])

  @@map("assets")
}

model CalaRecord {
  id             String   @id @default(uuid())
  schoolId       String   @map("school_id")
  studentId      String   @map("student_id")
  subjectId      String   @map("subject_id")
  termId         String   @map("term_id")
  taskName       String   @map("task_name")
  score          Float
